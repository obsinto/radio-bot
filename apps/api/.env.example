# API - servidor central
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:5173

# Use valores longos e aleatorios em producao.
JWT_SECRET=change-this-jwt-secret

# Criptografa usuario/senha dos perfis de radio no banco.
# IMPORTANTE: depois de cadastrar radios em producao, nao troque essa chave.
ENCRYPTION_KEY=change-this-32-plus-character-secret

ADMIN_EMAIL=admin@radio.local
ADMIN_PASSWORD=change-me

# Banco de dados (PostgreSQL)
# Producao/Coolify: preencha com a connection string do Postgres do Coolify.
# Para teste local rapido sem Postgres, deixe vazio (usa memoria, perde tudo ao reiniciar).
DATABASE_URL=postgresql://usuario:senha@host:5432/radio_bot

# Seeds opcionais. Mantenha [] para cadastrar tudo manualmente pelo painel.
SITE_PROFILES_JSON=[]
DEVICES_JSON=[]
WOL_GATEWAYS_JSON=[]

# Recuperacao automatica apos queda inesperada (Wake on LAN).
# Se um computador com MAC + gateway ESP configurados cair offline sem um
# "shutdown" agendado/manual recente, a API enfileira um power_on. O pacote WOL
# so e enviado quando o gateway ESP volta a fazer poll (ex.: quando a energia
# retorna), e a radio que estava tocando e restaurada na reconexao do agente.
# Dispensa o "restore on AC power loss" da BIOS.
AUTO_RECOVER_ENABLED=true
# Tempo (ms) que o PC precisa ficar offline antes de religar (ignora piscadas de rede).
AUTO_RECOVER_GRACE_MS=90000
# Intervalo minimo (ms) entre tentativas de WOL para o mesmo PC.
AUTO_RECOVER_BACKOFF_MS=300000
# Janela (ms) em torno da queda para considerar um "shutdown" nosso como intencional.
AUTO_RECOVER_INTENTIONAL_WINDOW_MS=900000

# O acesso inicial ao painel fica nas variaveis ADMIN_EMAIL e ADMIN_PASSWORD acima.

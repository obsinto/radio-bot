# API - servidor central
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:5173

# Use valores longos e aleatorios em producao.
JWT_SECRET=change-this-jwt-secret

# Criptografa usuario/senha dos perfis de radio no banco.
# IMPORTANTE: depois de cadastrar radios em producao, nao troque essa chave.
ENCRYPTION_KEY=change-this-32-plus-character-secret

ADMIN_EMAIL=admin@radio.local
ADMIN_PASSWORD=change-me

# Banco de dados (PostgreSQL)
# Producao/Coolify: preencha com a connection string do Postgres do Coolify.
# Para teste local rapido sem Postgres, deixe vazio (usa memoria, perde tudo ao reiniciar).
DATABASE_URL=postgresql://usuario:senha@host:5432/radio_bot

# Radios / perfis de acesso
# Com PostgreSQL, esta lista funciona como seed inicial.
SITE_PROFILES_JSON=[{"id":"palmeirinha-fm","name":"Palmeirinha FM","siteUrl":"https://app.radios.srv.br/?r=28357A55656E59517E735956676158546B73515E6370598DACD1EA","username":"","password":""}]

# Computadores / agentes locais
DEVICES_JSON=[{"id":"studio-01","name":"Studio 01","location":"Local principal","token":"change-studio-01-token","profileIds":["palmeirinha-fm"],"wolGatewayId":"esp-studio-01"},{"id":"studio-02","name":"Studio 02","location":"Segundo local","token":"change-studio-02-token","profileIds":["palmeirinha-fm"]}]

# Gateways ESP32 / Wake on LAN
WOL_GATEWAYS_JSON=[{"id":"esp-studio-01","name":"Gateway ESP32 Studio 01","location":"Local principal","token":"change-esp-studio-01-token"}]

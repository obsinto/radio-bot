# ============================================================
# API - servidor central
# ============================================================
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:5173

# Use valores longos e aleatorios em producao.
# JWT_SECRET assina sessoes do painel.
JWT_SECRET=change-this-jwt-secret

# ENCRYPTION_KEY criptografa usuario/senha dos perfis de radio no banco.
# IMPORTANTE: depois de cadastrar radios em producao, nao troque essa chave.
# Se trocar, as credenciais ja salvas nao poderao ser descriptografadas.
ENCRYPTION_KEY=change-this-32-plus-character-secret

ADMIN_EMAIL=admin@radio.local
ADMIN_PASSWORD=change-me

# ============================================================
# Banco de dados
# ============================================================
# Modo local rapido:
# - deixe DATABASE_URL vazio
# - a API usa memoria
# - radios/computadores/comandos somem ao reiniciar a API
#
# Modo producao/Coolify:
# - crie um PostgreSQL no Coolify
# - preencha DATABASE_URL com a connection string
# - a API cria as tabelas automaticamente
# - radios/computadores/comandos ficam persistidos
#
# Exemplo:
# DATABASE_URL=postgresql://usuario:senha@host:5432/radio_bot
DATABASE_URL=

# ============================================================
# Radios / perfis de acesso
# ============================================================
# Sem DATABASE_URL:
# - esta lista e carregada em memoria a cada start
#
# Com DATABASE_URL:
# - esta lista funciona como seed inicial
# - novos perfis cadastrados pelo painel ficam no PostgreSQL
# - usuario/senha sao armazenados criptografados
#
# Nao coloque credenciais reais em arquivos versionados.
SITE_PROFILES_JSON=[{"id":"oliveira-fm","name":"Oliveira FM","siteUrl":"http://app.radios.srv.br","username":"","password":""}]

# ============================================================
# Computadores / agentes locais
# ============================================================
# Cada instalacao do agente precisa ter DEVICE_ID e DEVICE_TOKEN proprios.
#
# Sem DATABASE_URL:
# - esta lista define os computadores disponiveis em memoria
#
# Com DATABASE_URL:
# - esta lista funciona como seed inicial
# - novos computadores cadastrados pelo painel ficam no PostgreSQL
# - tokens sao armazenados como hash, nao em texto puro
DEVICES_JSON=[{"id":"studio-01","name":"Studio 01","location":"Local principal","token":"change-studio-01-token","profileIds":["oliveira-fm"],"wolGatewayId":"esp-studio-01"},{"id":"studio-02","name":"Studio 02","location":"Segundo local","token":"change-studio-02-token","profileIds":["oliveira-fm"]}]

# ============================================================
# Gateways ESP32 / Wake on LAN
# ============================================================
# O gateway ESP32 fica na mesma rede local do computador que precisa acordar.
# Ele faz polling na API e envia o magic packet na LAN.
WOL_GATEWAYS_JSON=[{"id":"esp-studio-01","name":"Gateway ESP32 Studio 01","location":"Local principal","token":"change-esp-studio-01-token"}]

# ============================================================
# Web - painel
# ============================================================
# Local: http://localhost:3000
# Producao: https://api.seu-dominio.com
VITE_API_URL=http://localhost:3000

# ============================================================
# Agent - computador local controlado
# ============================================================
# Local: ws://localhost:3000/agent
# Producao com HTTPS: wss://api.seu-dominio.com/agent
SERVER_URL=ws://localhost:3000/agent

# Estes valores precisam bater com um computador cadastrado na API.
DEVICE_ID=studio-01
DEVICE_TOKEN=change-studio-01-token

# Perfil persistente do Chromium usado pelo Playwright.
# Mantem sessao/cookies do site quando possivel.
BROWSER_PROFILE_PATH=.cache/browser/studio-01

# false = navegador visivel na maquina local.
# true = roda sem janela, quando o ambiente permitir.
HEADLESS=false

# Mapa opcional para comandos click_action.
# Exemplo: {"play":"button[data-action='play']","stop":"button[data-action='stop']"}
ACTION_MAP_JSON={}

# Firmware ESP32 - Wake on LAN gateway
WIFI_SSID=sua-rede-wifi
WIFI_PASSWORD=senha-da-rede

API_BASE_URL=https://api.seu-dominio.com
WOL_GATEWAY_ID=seu-wol-gateway-id
WOL_GATEWAY_TOKEN=token-gerado-no-painel
USE_CONFIG_H_SEED=1
SERIAL_CONFIG_ONLY=0

POLL_INTERVAL_MS=5000
WOL_PORT=9
WOL_REPEAT_COUNT=3

# MVP: 1 facilita teste com HTTPS/Coolify sem embutir CA.
# Para producao endurecida, use 0 e preencha ROOT_CA_PEM.
TLS_INSECURE=1
ROOT_CA_PEM=
